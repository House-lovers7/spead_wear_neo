# このファイルをコピーして .env.local を作成してください:
#   cp env.example .env.local
# 実キーは絶対にコミットしないこと。

# === Vercel AI Gateway (任意 — 未設定ならモック解析で動く) ===
# https://vercel.com/docs/ai-gateway で発行
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-5
# AI_GATEWAY_MODEL_FAST=anthropic/claude-haiku-4.5

# === App ===
APP_URL=http://localhost:3000

# === デモゲート (任意 — 未設定ならゲート無効で全公開) ===
# 設定すると全ページ・APIが共有パスコード入力後のみ使える (ADR-0005)
# DEMO_PASSCODE=
